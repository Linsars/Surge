#!name = GPT / Gemini 支持检测面板
#!desc = 在模块设置中输入具体节点名称进行检测
#!author = Linsar
#!icon = https://raw.githubusercontent.com/getsomecat/GetSomeCats/main/icon/gpt.png

[Script]
GPT支持检测 = type=generic, timeout=120, script-path=https://raw.githubusercontent.com/Linsars/Surge/main/JS/egern-GPTjc.js

[Panel]
GPT / Gemini 支持 = script-name=GPT支持检测, icon=🔍, title=GPT/Gemini, style=info, update-interval=3600

[ENV]
NODE_NAME = 
  name = 要检测的节点名称
  desc = 请填你想检测的具体节点完整名称（不是策略组）
  type = text
  default = 
