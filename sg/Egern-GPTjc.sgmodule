#!name = GPT / Gemini 支持检测面板
#!desc = 检测指定策略组里的节点是否支持 GPT
#!author = Linsar
#!icon = https://raw.githubusercontent.com/getsomecat/GetSomeCats/main/icon/gpt.png

[Script]
GPT支持检测 = type=generic, timeout=120, script-path=https://raw.githubusercontent.com/Linsars/Surge/main/JS/egern-GPTjc.js, argument=你的策略组名称   // ← 这里改成你实际的策略组名！

[Panel]
GPT 支持检测 = script-name=GPT支持检测, icon=🔍, title=GPT/Gemini, style=info, update-interval=3600
